{
  "name": "hackathon-admin-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "cross-env NODE_ENV=development DATABASE_TYPE=sqlite next dev",
    "dev:prod": "cross-env NODE_ENV=development DATABASE_TYPE=postgresql next dev",
    "build": "prisma generate && next build",
    "build:local": "cross-env DATABASE_TYPE=sqlite prisma generate && next build",
    "build:prod": "cross-env DATABASE_TYPE=postgresql prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:migrate:local": "cross-env DATABASE_TYPE=sqlite prisma migrate dev",
    "prisma:migrate:prod": "cross-env DATABASE_TYPE=postgresql prisma migrate deploy",
    "prisma:studio:local": "cross-env DATABASE_TYPE=sqlite prisma studio",
    "prisma:studio:prod": "cross-env DATABASE_TYPE=postgresql prisma studio"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.12.0",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.12",
    "@tanstack/react-table": "^8.21.3",
    "@types/formidable": "^3.4.5",
    "@types/moment": "^2.11.29",
    "@types/react-big-calendar": "^1.16.2",
    "@vercel/blob": "^1.1.1",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "formidable": "^3.5.4",
    "framer-motion": "^10.18.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.309.0",
    "moment": "^2.30.1",
    "next": "14.0.4",
    "next-themes": "^0.4.6",
    "prisma": "^6.12.0",
    "react": "^18",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^18",
    "recharts": "^3.1.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "cross-env": "^10.0.0",
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
