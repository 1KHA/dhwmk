// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Database configuration
datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
}

model Team {
  id                   String    @id @default(cuid())
  teamName             String?
  status               String    @default("pending") // pending, approved, rejected
  hackathonTrack       String?   // NEW: أي مسار من مسارات الهاكاثون؟
  ideaDescription      String?   // SIMPLIFIED: صف الفكرة
  hearAboutUs          String?   // NEW: من أين سمعت عنا
  isTeamRegistration   Boolean   @default(true) // NEW: distinguish team vs individual
  attachmentPath       String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  participants         Participant[]
  receivedJoinRequests TeamJoinRequest[]
  
  // DEPRECATED FIELDS - Keep for backward compatibility
  challenge            String?
  challengeReason      String?
  ideaName             String?
  ideaSolution         String?
  ideaResults          String?
  ideaStage            String?
  attachmentsLink      String?
  hasParticipated      Boolean?
  participationDetails String?
}

model Participant {
  id                   String                @id @default(cuid())
  // NEW CSV-based fields
  fullName             String?               // الاسم كاملًا
  contactNumber        String?               // رقم التواصل
  gender               String?               // الجنس المتقدم: ذكر أم أنثى؟
  isUniversityStudent  Boolean?              // هل أنت طالب في الجامعة؟
  universityMajor      String?               // اذكر تخصصك الجامعي
  professionalField    String?               // ماهو مجالك المهني؟
  city                 String?               // المدينة
  canAttendHackathon   Boolean?              // هل تستطيع التواجد خلال فترة الهاكاثون؟
  
  // Core fields
  email                String                @unique
  university           String?               // اذكر جامعتك
  isLeader             Boolean               @default(false)
  passwordHash         String?
  status               String                @default("pending") // pending, approved, rejected (for individual participants)
  teamId               String?               // Make optional for individual participants
  team                 Team?                 @relation(fields: [teamId], references: [id])
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  bookings             MentorBooking[]
  submissions          MilestoneSubmission[]
  eventRegistrations   EventRegistration[]
  sentJoinRequests     TeamJoinRequest[]
  
  // DEPRECATED FIELDS - Keep for backward compatibility
  firstName            String?
  secondName           String?
  familyName           String?
  nationalId           String?
  dob                  String?
  phoneNumber          String?
  education            String?
  major                String?
  employmentStatus     String?
  nationality          String?
  residence            String?
  canAttend            Boolean?
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Mentor {
  id             String               @id @default(cuid())
  name           String
  email          String               @unique
  specialty      String
  phone          String
  status         String               @default("pending") // pending, active, inactive
  passwordHash   String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  availabilities MentorAvailability[]
}

model MentorAvailability {
  id        String          @id @default(cuid())
  startTime DateTime
  endTime   DateTime
  mentorId  String
  mentor    Mentor          @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  bookings  MentorBooking[]
}

model MentorBooking {
  id             String             @id @default(cuid())
  participantId  String
  participant    Participant        @relation(fields: [participantId], references: [id])
  availabilityId String
  availability   MentorAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  status         String             @default("booked") // booked, cancelled, completed
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model Milestone {
  id              String                @id @default(cuid())
  title           String
  description     String
  dueDate         DateTime
  status          String                @default("upcoming") // upcoming, active, completed, overdue
  requirements    String                // JSON string of requirements array
  submissionCount Int                   @default(0)
  submissionLink  String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  submissions     MilestoneSubmission[]
}

model MilestoneSubmission {
  id            String      @id @default(cuid())
  participant   Participant @relation(fields: [participantId], references: [id])
  participantId String
  milestone     Milestone   @relation(fields: [milestoneId], references: [id])
  milestoneId   String
  filePath      String
  fileName      String
  submittedAt   DateTime    @default(now())
  reviewStatus  String?     // accepted, rejected, pending
  reviewComment String?     // Admin's comment on the submission
  reviewedAt    DateTime?   // When the submission was reviewed

  @@unique([participantId, milestoneId])
}

model Event {
  id           String             @id @default(cuid())
  title        String
  description  String
  startDate    DateTime
  endDate      DateTime
  location     String
  capacity     Int
  type         String
  plan         String
  presenter    String
  status       String             @default("upcoming") // upcoming, active, completed, cancelled
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  registrations EventRegistration[]
}

model EventRegistration {
  id            String      @id @default(cuid())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id])
  eventId       String
  event         Event       @relation(fields: [eventId], references: [id])
  status        String      @default("registered") // registered, cancelled, attended, absent
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([participantId, eventId])
}

model Notification {
  id                String    @id @default(cuid())
  title             String    // Short notification title
  message           String    // Detailed notification message
  type              String    // success, info, warning, error
  isRead            Boolean   @default(false)
  recipientType     String    // admin, participant, mentor
  recipientId       String    // ID of the recipient
  relatedEntityType String?   // team, event, milestone, mentor, participant
  relatedEntityId   String?   // ID of related entity
  actionUrl         String?   // Optional URL for clickable notifications
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model TeamJoinRequest {
  id            String   @id @default(cuid())
  participantId String   // Individual requesting to join
  teamId        String   // Team they want to join
  status        String   @default("pending") // pending, accepted, rejected
  message       String?  // Optional message from participant
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  participant   Participant @relation(fields: [participantId], references: [id])
  team          Team        @relation(fields: [teamId], references: [id])
  
  @@unique([participantId, teamId]) // Prevent duplicate requests
}
