// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Team {
  id                   String    @id @default(cuid())
  teamName             String
  status               String    @default("pending") // pending, approved, rejected
  challenge            String
  challengeReason      String
  ideaName             String
  ideaDescription      String
  ideaSolution         String
  ideaResults          String
  ideaStage            String
  attachmentsLink      String?
  hasParticipated      Boolean
  participationDetails String?
  attachmentPath       String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  participants         Participant[]
}

model Participant {
  id               String                @id @default(cuid())
  firstName        String
  secondName       String
  familyName       String
  nationalId       String
  dob              String
  email            String                @unique
  phoneNumber      String
  education        String
  university       String
  major            String
  employmentStatus String
  nationality      String
  residence        String
  canAttend        Boolean
  isLeader         Boolean               @default(false)
  passwordHash     String?
  teamId           String
  team             Team                  @relation(fields: [teamId], references: [id])
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  bookings         MentorBooking[]
  submissions      MilestoneSubmission[]
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Mentor {
  id             String               @id @default(cuid())
  name           String
  email          String               @unique
  specialty      String
  phone          String
  status         String               @default("pending") // pending, active, inactive
  passwordHash   String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  availabilities MentorAvailability[]
}

model MentorAvailability {
  id        String          @id @default(cuid())
  startTime DateTime
  endTime   DateTime
  mentorId  String
  mentor    Mentor          @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  bookings  MentorBooking[]
}

model MentorBooking {
  id             String             @id @default(cuid())
  participantId  String
  participant    Participant        @relation(fields: [participantId], references: [id])
  availabilityId String
  availability   MentorAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  status         String             @default("booked") // booked, cancelled, completed
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model Milestone {
  id              String                @id @default(cuid())
  title           String
  description     String
  dueDate         DateTime
  status          String                @default("upcoming") // upcoming, active, completed, overdue
  requirements    String                // JSON string of requirements array
  submissionCount Int                   @default(0)
  submissionLink  String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  submissions     MilestoneSubmission[]
}

model MilestoneSubmission {
  id            String      @id @default(cuid())
  participant   Participant @relation(fields: [participantId], references: [id])
  participantId String
  milestone     Milestone   @relation(fields: [milestoneId], references: [id])
  milestoneId   String
  filePath      String
  fileName      String
  submittedAt   DateTime    @default(now())
  reviewStatus  String?     // accepted, rejected, pending
  reviewComment String?     // Admin's comment on the submission
  reviewedAt    DateTime?   // When the submission was reviewed

  @@unique([participantId, milestoneId])
}
